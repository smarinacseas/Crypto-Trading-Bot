# Database Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Frontend Environment Variables (React)
REACT_APP_SUPABASE_URL=your_supabase_url_here
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ENCRYPTION_KEY=your-encryption-key-32-bytes-long-change-this

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# Exchange API Keys (Optional - for trading features)
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET_KEY=your_mexc_secret_key_here

HYPERLIQUID_SECRET_KEY=your_hyperliquid_private_key_here

# Development Settings
ENVIRONMENT=development
LOG_LEVEL=INFO