# Database
# SQLite (default, single-file). Use absolute path or relative to repo root.
DATABASE_URL=sqlite:///./backend/data/app.db
# Postgres example (when you graduate):
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/stockdash

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Auth (currently disabled; flip on when adding multi-user)
AUTH_ENABLED=false
SECRET_KEY=change-me-when-you-enable-auth

# Stock data refresh
DEFAULT_UNIVERSE_FILE=backend/app/data/sp500.txt
REFRESH_BATCH_SIZE=25
REFRESH_RATE_LIMIT_SECONDS=0.5

# Logging
LOG_LEVEL=INFO
